{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Issuer": "fitcoach-identity",
    "Audience": "fitcoach",
    "SigningKey": ""
  },
  "ReverseProxy": {
    "Routes": {
      "identity-login": {
        "ClusterId": "identity",
        "AuthorizationPolicy": "anonymous",
        "Order": 1,
        "Match": {
          "Path": "/api/auth/login",
          "Methods": [ "POST" ]
        }
      },
      "identity-signup": {
        "ClusterId": "identity",
        "AuthorizationPolicy": "anonymous",
        "Order": 1,
        "Match": {
          "Path": "/api/auth/signup",
          "Methods": [ "POST" ]
        }
      },
      "identity-protected": {
        "ClusterId": "identity",
        "AuthorizationPolicy": "default",
        "Order": 2,
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
      },
      "program-exercises": {
        "ClusterId": "program",
        "AuthorizationPolicy": "default",
        "Match": { "Path": "/api/exercises/{**catch-all}" }
      },
      "program-programs": {
        "ClusterId": "program",
        "AuthorizationPolicy": "default",
        "Match": { "Path": "/api/programs/{**catch-all}" }
      },
      "program-workouts": {
        "ClusterId": "program",
        "AuthorizationPolicy": "default",
        "Match": { "Path": "/api/workouts/{**catch-all}" }
      },
      "program-me-programs": {
        "ClusterId": "program",
        "AuthorizationPolicy": "default",
        "Match": { "Path": "/api/me/programs" }
      },
      "tracking-workout-logs": {
        "ClusterId": "tracking",
        "AuthorizationPolicy": "default",
        "Match": { "Path": "/api/workout-logs/{**catch-all}" }
      },
      "tracking-nutrition": {
        "ClusterId": "tracking",
        "AuthorizationPolicy": "default",
        "Match": { "Path": "/api/nutrition-entries/{**catch-all}" }
      },
      "tracking-client-logs": {
        "ClusterId": "tracking",
        "AuthorizationPolicy": "default",
        "Match": { "Path": "/api/clients/{**catch-all}" }
      }
    },
    "Clusters": {
      "identity": {
        "Destinations": {
          "identity-service": {
            "Address": "http://identity-service:8080"
          }
        }
      },
      "program": {
        "Destinations": {
          "program-service": {
            "Address": "http://program-service:8080"
          }
        }
      },
      "tracking": {
        "Destinations": {
          "tracking-service": {
            "Address": "http://tracking-service:8080"
          }
        }
      }
    }
  }
}
